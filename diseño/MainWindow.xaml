<Window x:Class="YourApp.PropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Properties"
        Width="950" Height="520"
        WindowStartupLocation="CenterScreen"
        Background="#FFF7F7F9">

    <Window.Resources>

        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#FF1F2937"/>
        </Style>

        <Style x:Key="ColumnCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFE5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>

        <Style x:Key="ColumnTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#FF2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF2563EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#FF111827"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
        </Style>

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Properties"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Column Layout -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto">
            <StackPanel Orientation="Horizontal">

                <!-- FAMILY -->
                <Border Style="{StaticResource ColumnCard}">
                    <StackPanel>
                        <TextBlock Text="Family" Style="{StaticResource ColumnTitle}"/>
                        <RadioButton Content="Times" GroupName="Family" IsChecked="True"/>
                        <RadioButton Content="Helvetica" GroupName="Family"/>
                        <RadioButton Content="Courier" GroupName="Family"/>
                        <RadioButton Content="Sans serif" GroupName="Family"/>
                    </StackPanel>
                </Border>

                <!-- SIZE -->
                <Border Style="{StaticResource ColumnCard}">
                    <StackPanel>
                        <TextBlock Text="Size" Style="{StaticResource ColumnTitle}"/>
                        <RadioButton Content="Small" GroupName="Size" IsChecked="True"/>
                        <RadioButton Content="Medium" GroupName="Size"/>
                        <RadioButton Content="Large" GroupName="Size"/>
                    </StackPanel>
                </Border>

                <!-- STYLE -->
                <Border Style="{StaticResource ColumnCard}">
                    <StackPanel>
                        <TextBlock Text="Style" Style="{StaticResource ColumnTitle}"/>
                        <CheckBox Content="Bold"/>
                        <CheckBox Content="Underline"/>
                        <CheckBox Content="Italic"/>
                    </StackPanel>
                </Border>

                <!-- PITCH -->
                <Border Style="{StaticResource ColumnCard}">
                    <StackPanel>
                        <TextBlock Text="Pitch" Style="{StaticResource ColumnTitle}"/>
                        <RadioButton Content="10 CPI" GroupName="Pitch" IsChecked="True"/>
                        <RadioButton Content="12 CPI" GroupName="Pitch"/>
                        <RadioButton Content="15 CPI" GroupName="Pitch"/>
                        <RadioButton Content="Proportional" GroupName="Pitch"/>
                    </StackPanel>
                </Border>

                <!-- COLOR -->
                <Border Style="{StaticResource ColumnCard}">
                    <StackPanel>
                        <TextBlock Text="Color" Style="{StaticResource ColumnTitle}"/>
                        <RadioButton Content="Black" GroupName="Color" IsChecked="True"/>
                        <RadioButton Content="Blue" GroupName="Color"/>
                        <RadioButton Content="Red" GroupName="Color"/>
                        <RadioButton Content="Green" GroupName="Color"/>
                    </StackPanel>
                </Border>

                <!-- BORDER -->
                <Border Style="{StaticResource ColumnCard}">
                    <StackPanel>
                        <TextBlock Text="Border" Style="{StaticResource ColumnTitle}"/>

                        <RadioButton GroupName="Border" IsChecked="True">
                            <Border Height="14" BorderBrush="Black" BorderThickness="1"/>
                        </RadioButton>

                        <RadioButton GroupName="Border">
                            <Border Height="14" BorderBrush="Black" BorderThickness="2"/>
                        </RadioButton>

                        <RadioButton GroupName="Border">
                            <Border Height="14" BorderBrush="Black" BorderThickness="4"/>
                        </RadioButton>

                        <RadioButton GroupName="Border">
                            <Border Height="14" Background="Black"/>
                        </RadioButton>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,377,0">

            <Button Content="OK"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,0,10,0"/>

            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,10,0"/>

            <Button Content="Apply"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,10,0"/>

            <Button Content="Help"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#FF2563EB"
                    Cursor="Hand"/>

        </StackPanel>

    </Grid>
</Window>